  "keyFeatures": [
    "Modular Monolith Architecture with clear bounded contexts",
    "Clean Architecture with strict layer separation",
    "Domain-Driven Design with Aggregates and Value Objects",
    "JWT Authentication with Role-Based Access Control (RBAC)",
    "Google OAuth integration",
    "Stripe payment processing",
    "Azure Blob Storage for media management",
    "Content moderation with Toxicity API",
    "PostgreSQL with separate schemas per module",
    ".NET Aspire for cloud-native orchestration",
    "Result Pattern for explicit error handling",
    "Minimal API endpoints following REPR pattern",
    "In-memory event bus for inter-module communication",
    "Guid V7 for time-sortable identifiers"
  ],
  "publicApiSurface": [
    "POST /api/account/customer/register - Register new customer",
    "POST /api/account/roles - Login and get user roles",
    "POST /api/account/token - Get JWT token by role",
    "POST /api/account/customer/google - Continue with Google OAuth",
    "POST /api/products - Create product (Seller)",
    "GET /api/products/product/{productId} - Get product details",
    "GET /api/products/category/{categoryId}/page/{page} - Get products by category",
    "POST /api/products/product/{productId}/discount - Add discount to product",
    "POST /api/products/{productId}/reviews - Add product review",
    "GET /api/products/{productId}/reviews - Get product reviews",
    "POST /api/orders - Create new order",
    "GET /api/orders/{orderId} - Get order details",
    "POST /api/orders/{orderId}/payment - Process payment",
    "GET /api/cart - Get customer cart",
    "POST /api/cart/items - Add item to cart",
    "GET /api/wishlist - Get customer wishlist",
    "POST /api/media/upload - Upload media file",
    "POST /api/seller/application - Submit seller application",
    "GET /api/seller/shop - Get seller shop details",
    "POST /api/support/tickets - Create support ticket"
  ]
}
